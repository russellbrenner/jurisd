{
  "name": "jurisd",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Australian legislation and case law search.",
  "main": "dist/index.js",
  "bin": {
    "jurisd": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs'),p=require('path');fs.mkdirSync('dist/data',{recursive:true});fs.copyFileSync('src/data/manifest.schema.json','dist/data/manifest.schema.json')\"",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run src/test/smoke/",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "docs": "typedoc",
    "docs:serve": "npx serve docs/api",
    "prepare": "(husky || exit 0) && node -e \"const p=require('path'),cp=require('child_process');if(process.env.INIT_CWD&&p.resolve(process.env.INIT_CWD)!==process.cwd())cp.execSync('npm run build',{stdio:'inherit'})\""
  },
  "keywords": [
    "model-context-protocol",
    "australian-law",
    "mcp-server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/russellbrenner/jurisd.git"
  },
  "homepage": "https://github.com/russellbrenner/jurisd#readme",
  "bugs": {
    "url": "https://github.com/russellbrenner/jurisd/issues"
  },
  "author": "Russell Brenner",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.3",
    "@huggingface/transformers": "^3.7.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "cheerio": "^1.1.2",
    "dotenv": "^17.4.2",
    "file-type": "^21.3.0",
    "pdf-parse": "^2.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^24.13.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "impit": "^0.14.1"
  }
}
